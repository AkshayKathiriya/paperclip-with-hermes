# ── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
PEXELS_API_KEY=your-pexels-api-key

# ── Optional (defaults shown) ─────────────────────────────────────────────────
PORT=5000
OUTPUT_DIR=/tmp/youtube-worker/videos
PIPER_MODEL_DIR=/tmp/youtube-worker/piper-models
WHISPER_MODEL=base

# Set this to your Railway public URL when deployed
WORKER_PUBLIC_URL=http://localhost:5000
