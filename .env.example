# ── Required ───────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string

# ── Postgres (local only — Railway injects DATABASE_URL automatically) ─────────
POSTGRES_PASSWORD=paperclip

# ── Public URL ─────────────────────────────────────────────────────────────────
# Local: http://localhost:3100
# Railway: https://${{RAILWAY_PUBLIC_DOMAIN}}
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# ── LLM API keys — at least one required ──────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── YouTube worker ─────────────────────────────────────────────────────────────
PEXELS_API_KEY=
# Whisper model size: tiny | base | small | medium  (larger = slower + accurate)
WHISPER_MODEL=base
