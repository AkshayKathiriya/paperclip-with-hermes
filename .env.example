# ─────────────────────────────────────────────────────────────────────────────
#   YouTube AI Studio — environment template
#   Copy to `.env` and fill in keys. `.env` is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required: Paperclip auth + DB ──────────────────────────────────────────────
BETTER_AUTH_SECRET=change-me-to-a-random-32-char-string
POSTGRES_PASSWORD=paperclip

# Local: http://localhost:3100   |   Railway: https://${{RAILWAY_PUBLIC_DOMAIN}}
PAPERCLIP_PUBLIC_URL=http://localhost:3100


# ── Required: LLM keys ────────────────────────────────────────────────────────
# Anthropic — primary LLM provider for Scriptwriter, Scene Director, Researcher
# (Paperclip agents using claude-local adapter)
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — gpt-image-1 for AI image generation (Phase 2) + thumbnails
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# OpenRouter — multi-provider router for DeepSeek / Qwen / Kimi / Llama
# Used by opencode-local adapter for the CEO + Production Manager + Publisher
# https://openrouter.ai/keys           [PHASE 3 — needed for cost optimization]
OPENROUTER_API_KEY=


# ── Required: worker assets ───────────────────────────────────────────────────
# Pexels — stock B-roll footage
# https://www.pexels.com/api
PEXELS_API_KEY=

# Whisper model size: tiny | base | small | medium  (larger = slower + accurate)
WHISPER_MODEL=base


# ── Required: ElevenLabs (narration TTS) ───────────────────────────────────────
# https://elevenlabs.io/app/settings/api-keys
# Pick a voice ID from https://elevenlabs.io/app/voice-library
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_turbo_v2_5


# ── Phase 3 (next): MCP server credentials for Researcher ──────────────────────
# Brave Search API — feeds the Researcher's web-search MCP
# https://api-dashboard.search.brave.com/app/keys     (2,000 queries/mo free)
BRAVE_SEARCH_API_KEY=

# OR Tavily Search API — alternative to Brave
# https://app.tavily.com/                              (1,000 queries/mo free)
TAVILY_API_KEY=


# ── Phase 5 (deferred): YouTube auto-publishing ───────────────────────────────
# Will be filled in once we move to publishing. Not needed for video assembly.
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REFRESH_TOKEN=
# YOUTUBE_CHANNEL_ID=
