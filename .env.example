# Required
BETTER_AUTH_SECRET=change-me-to-a-random-string

# Postgres (only for local docker-compose; Railway injects DATABASE_URL automatically)
POSTGRES_PASSWORD=paperclip

# Public URL (Railway sets this via $RAILWAY_PUBLIC_DOMAIN)
PAPERCLIP_PUBLIC_URL=http://localhost:3100

# LLM API keys — at least one is required for Hermes Agent
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
